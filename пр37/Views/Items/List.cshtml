@model IEnumerable<пр37.Data.Models.Items>
@{
    Layout = "_Layout";
    ViewBag.Title = "Каталог товаров";
}

<h2>Все предметы</h2>

@foreach (var item in Model)
{
    <div class="mb-3 p-3 border rounded">
        <h3>Модель: @item.Name</h3>
        <p>Цена: @item.Price.ToString("c")</p>
        <p>Категория: @(item.Category?.Name ?? "Не указана")</p>
    </div>
}