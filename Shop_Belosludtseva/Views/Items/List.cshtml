@using Shop_Belosludtseva.Data.ViewModell

@model VMItems

@{
    Layout = "_Layout";
}

<div>
    <select onChange="SelectCategory(this)">
        <option value="0">Выбрать ...</option>
        @foreach (var Category in Model.Categories)
        {
            if (Category.Id == Model.SelectCategory)
            {
                <option selected="selected" value="@Category.Id">@Category.Name</option>
            }
            else
            {
                <option value="@Category.Id">@Category.Name</option>
            }
        }
    </select>
    <script>
        function SelectCategory(sender) {
            window.location = "/Items/List?id=" + sender.value;
        }
    </script>
</div>

<h2>Все предметы</h2>

@foreach (var item in Model.Items)
{
    // Показываем только товары выбранной категории или все, если категория не выбрана
    if (item.Category.Id == Model.SelectCategory || Model.SelectCategory == 0)
    {
        <div class="item" style="border: 1px solid #ddd; padding: 15px; margin: 10px 0; border-radius: 5px;">
            <img src="@item.Img" alt="@item.Name" style="max-width: 200px; display: block; margin-bottom: 10px;" />

            <div class="data">
                <h3>Модель: @item.Name</h3>
                <div>Цена: @item.Price.ToString("c")</div>
                <div>Категория: @item.Category.Name</div>
                <div>Описание: @item.Description</div>
            </div>

            <!-- ✅ Кнопки управления -->
            <div class="actions" style="margin-top: 15px;">
                <a href="/Items/Update?id=@item.Id"
                   class="btn-edit"
                   style="display: inline-block; padding: 8px 16px; margin-right: 10px;
                                  background-color: #007bff; color: white; text-decoration: none;
                                  border-radius: 4px; font-size: 14px;">
                    Изменить
                </a>

                <a href="/Items/Delete?id=@item.Id"
                   class="btn-delete"
                   style="display: inline-block; padding: 8px 16px;
                                  background-color: #dc3545; color: white; text-decoration: none;
                                  border-radius: 4px; font-size: 14px;"
                   onclick="return confirm('Вы уверены, что хотите удалить предмет &quot;@item.Name&quot;?');">
                    Удалить
                </a>
            </div>
        </div>
    }
}