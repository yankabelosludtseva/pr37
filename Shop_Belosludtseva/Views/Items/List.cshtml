@using Shop_Belosludtseva.Data.ViewModell
@model VMItems

@{
    Layout = "_Layout";
    ViewBag.Title = "Все предметы";
}

<!-- Счётчик корзины -->
<div class="basket-counter">
    🛒 Корзина: <span id="basket-count">0</span>
</div>

<!-- Фильтр по категориям -->
<div class="category-filter">
    <select id="category-select" onchange="SelectCategory(this)">
        <option value="0">Выбрать ...</option>
        @foreach (var category in Model.Categories)
        {
            var selected = category.Id == Model.SelectCategory ? "selected" : "";
            <option value="@category.Id" @selected>@category.Name</option>
        }
    </select>
</div>

<h2>Все предметы</h2>

<!-- Список товаров -->
<div class="items-list">
    @foreach (var item in Model.Items)
    {
        // Показываем только товары выбранной категории или все, если категория не выбрана
        if (item.Category?.Id == Model.SelectCategory || Model.SelectCategory == 0)
        {
            <div class="item-card">
                <img src="@item.Img" alt="@item.Name" class="item-image" />

                <div class="item-data">
                    <h3 class="item-name">Модель: @item.Name</h3>
                    <div class="item-price">Цена: @item.Price ₽</div>
                    <div class="item-category">Категория: @item.Category?.Name</div>
                    <div class="item-description">Описание: @item.Description</div>
                </div>

                <div class="item-actions">
                    <!-- Кнопка "В корзину" с классом basket и ID -->
                    <button type="button"
                            id="@item.Id"
                            class="basket btn-basket"
                            data-id="@item.Id"
                            data-name="@item.Name"
                            data-price="@item.Price">
                        В корзину
                    </button>

                    <!-- Элемент счётчика с кнопкой "-" (изначально скрыт) -->
                    <span class="count" style="display: none; color: #28a745; font-weight: bold; align-items: center; gap: 5px;">
                        <button type="button" class="min" style="padding: 2px 8px; cursor: pointer;">-</button>
                        <span class="text">1</span>
                    </span>

                    <a href="/Items/Update?id=@item.Id" class="btn-edit">
                        Изменить
                    </a>

                    <a href="/Items/Delete?id=@item.Id"
                       class="btn-delete"
                       onclick="return confirm('Вы уверены, что хотите удалить предмет «@item.Name»?');">
                        Удалить
                    </a>
                </div>
            </div>
        }
    }
</div>

<!-- Скрипт корзины -->
@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Обновление счётчика корзины
        function updateBasketCount() {
            const basket = JSON.parse(localStorage.getItem('basket') || '[]');
            const count = basket.reduce((sum, i) => sum + (i.quantity || 1), 0);
            const counter = document.getElementById('basket-count');
            if (counter) {
                counter.textContent = count;
            }
        }

        // Добавление товара в корзину (localStorage)
        function addToBasket(id, name, price) {
            const item = {
                id: id,
                name: name,
                price: parseInt(price, 10),
                quantity: 1
            };

            let basket = JSON.parse(localStorage.getItem('basket') || '[]');
            const existing = basket.find(i => i.id === item.id);

            if (existing) {
                existing.quantity += 1;
            } else {
                basket.push(item);
            }

            localStorage.setItem('basket', JSON.stringify(basket));
            updateBasketCount();
        }

        // Инициализация при загрузке страницы
        document.addEventListener('DOMContentLoaded', function() {
            updateBasketCount();

            // Навешиваем обработчики на кнопки "В корзину"
            document.querySelectorAll('.basket').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    const id = this.dataset.id;
                    const name = this.dataset.name;
                    const price = this.dataset.price;
                    addToBasket(id, name, price);
                });
            });
        });

        // Фильтрация по категории
        function SelectCategory(sender) {
            window.location = '/Items/List?id=' + sender.value;
        }

        // ==========================================
        // Код для кнопки "+" (добавление)
        // ==========================================
        $(".item-card").children(".basket").click(function () {
            // показываем элемент с классом count
            $(this).parent().children(".count").show();
            // скрываем кнопку
            $(this).hide();
            // вызываем AJAX
            $.ajax({
                // контроллер выполнения и метод вызываемый в нём
                url: '@Url.Action("Basket", "Items")',
                // тип данных которые отправляем
                contentType: "application/json; charset=utf-8",
                // передаём ID предмета
                data: JSON.stringify({ idItem: $(this).attr('id') }),
                // тип данных, ожидаемых от сервера.
                dataType: "json",
                // метод HTTP
                type: "POST",
                // Функция успешного выполнения
                success: SuccessBasket,
                // функция не успешного выполнения
                error: AjaxError
            });
        });

        // ==========================================
        // Код для кнопки "-" (уменьшение)
        // ==========================================
        $(".count").children(".min").click(function () {
            // получаем ID оборудования
            var idItem = $(this).parent().parent().children('.basket').attr('id');
            // получаем кол-во
            var count = $(this).parent().children(".text").text();
            // уменьшаем кол-во
            count--;
            // если кол-во = 0
            if (count == 0) {
                // показываем кнопку
                $(this).parent().parent().children('.basket').show();
                // скрываем каунтер
                $(this).parent().parent().children('.count').hide();
            } else {
                // изменяем текст
                $(this).parent().children(".text").text(count);
            }

            // вызываем AJAX
            $.ajax({
                // контроллер выполнения и метод вызываемый в нём
                url: '@Url.Action("BasketCount", "Items")',
                // тип данных которые отправляем
                contentType: "application/json; charset=utf-8",
                // передаём ID предмета и кол-во
                data: JSON.stringify({ idItem: idItem, count: count }),
                // тип данных, ожидаемых от сервера.
                dataType: "json",
                // метод HTTP
                type: "POST",
                // Функция успешного выполнения
                success: SuccessBasket,
                // функция не успешного выполнения
                error: AjaxError
            });
        });

        // Функция успешного выполнения
        function SuccessBasket(data) {
            console.log(data);
            // Обновляем общий счётчик корзины
            updateBasketCount();
        }

        // Функция не успешного выполнения
        function AjaxError() {
            console.log("Ошибка выполнения ajax");
        }
    </script>
}